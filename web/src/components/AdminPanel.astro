---
const isPreview = import.meta.env.PUBLIC_IS_PREVIEW !== 'false';
const { themeSlug = 'simulator', hidePdf = false } = Astro.props;
---

{isPreview && (
  <div class="fixed bottom-6 right-6 z-[100] group">
    <!-- Main Floating Button -->
    <button class="bg-slate-900 text-white w-14 h-14 rounded-full shadow-2xl flex items-center justify-center hover:bg-slate-800 transition transform hover:scale-105 border-2 border-slate-700">
      <i data-lucide="settings" class="w-6 h-6 hover:animate-spin"></i>
    </button>
    
    <!-- Expanded Panel -->
    <div class="absolute bottom-16 right-0 mb-2 w-72 bg-white rounded-2xl shadow-2xl border border-slate-200 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-bottom-right scale-95 group-hover:scale-100 p-4">
      <div class="border-b border-slate-100 pb-3 mb-3">
        <h3 class="font-black text-slate-800 flex items-center gap-2 text-sm">
          <i data-lucide="shield-check" class="w-5 h-5 text-emerald-500"></i>
          管理者プレビューモード
        </h3>
        <p class="text-[10px] text-slate-500 mt-1 leading-relaxed">このパネルは社長確認・開発者向けのプレビューサイト専用です。本番ソースには出力されません。</p>
      </div>
      
      <div class="space-y-3">
        <!-- PDF Download Button -->
        {!hidePdf && (
        <a href={`/slides/${themeSlug}_presentation.pdf`} target="_blank" class="w-full flex items-center justify-between bg-blue-50 hover:bg-blue-100 text-blue-700 border border-blue-200 rounded-lg px-3 py-3 transition group/btn shadow-sm">
          <div class="flex items-center gap-2 font-bold text-sm">
            <i data-lucide="file-text" class="w-5 h-5"></i>
            営業用 提案スライド (PDF)
          </div>
          <i data-lucide="external-link" class="w-4 h-4 opacity-50 group-hover/btn:opacity-100 transition"></i>
        </a>
        )}

        <!-- ZIP Download Button -->
        <a href="/production-build.zip" class="w-full flex items-center justify-between bg-orange-50 hover:bg-orange-100 text-orange-700 border border-orange-200 rounded-lg px-3 py-3 transition group/btn shadow-sm">
          <div class="flex items-center gap-2 font-bold text-sm">
            <i data-lucide="package" class="w-5 h-5"></i>
            本番用コード (ZIP)
          </div>
          <i data-lucide="download" class="w-4 h-4 opacity-50 group-hover/btn:opacity-100 transition"></i>
        </a>
        <p class="text-[10px] text-slate-400 px-1 leading-tight">※社外秘の提案書(PDF)や裏側データを除外した、自社サイト公開用のクリーンなHTML群がダウンロードできます。</p>
      </div>
    </div>
  </div>
)}
