---
const { theme } = Astro.props;

// Determine colors based on theme ID
const colorMap = {
  "01": { bg: "bg-blue-100", text: "text-blue-700", border: "border-blue-600", icon: "blue-500", rightBg: "bg-blue-500" },
  "02": { bg: "bg-green-100", text: "text-green-700", border: "border-green-600", icon: "green-500", rightBg: "bg-green-500" },
  "03": { bg: "bg-yellow-100", text: "text-yellow-700", border: "border-yellow-600", icon: "yellow-500", rightBg: "bg-yellow-500" },
  "04": { bg: "bg-purple-100", text: "text-purple-700", border: "border-purple-600", icon: "purple-500", rightBg: "bg-purple-500" },
  "05": { bg: "bg-red-100", text: "text-red-700", border: "border-red-600", icon: "red-500", rightBg: "bg-red-500" },
  "06": { bg: "bg-orange-100", text: "text-orange-700", border: "border-orange-600", icon: "orange-500", rightBg: "bg-orange-500" },
  "07": { bg: "bg-indigo-100", text: "text-indigo-700", border: "border-indigo-600", icon: "indigo-500", rightBg: "bg-indigo-500" }
};

const c = colorMap[theme.id] || colorMap["01"];

// Alternating layout
const isEven = parseInt(theme.id) % 2 === 0;
const flexRow = isEven ? "md:flex-row-reverse" : "md:flex-row";
const isNew = parseInt(theme.id) >= 6;
---

<div data-theme-id={theme.id}
    class={`theme-card bg-white rounded-3xl shadow-xl border border-slate-200 p-8 md:p-10 flex flex-col ${flexRow} gap-8 items-center relative overflow-hidden ${isNew ? `border-l-8 border-l-${c.icon.split('-')[0]}-500` : ''}`}>
    
    {isNew && (
        <div class={`absolute top-0 ${isEven ? 'left-0 rounded-br-xl' : 'right-0 rounded-bl-xl'} bg-red-500 text-white font-bold px-4 py-1 text-xs z-20`}>NEW</div>
    )}

    <div class="md:w-1/2">
        <span class={`px-4 py-1.5 ${c.bg} ${c.text} font-bold rounded-full text-sm mb-4 inline-block`}>Theme {theme.id}</span>
        <h3 class="text-3xl font-black text-slate-800 mb-1" data-theme-target="title">{theme.title}</h3>
        <p class={`font-bold ${c.text} mb-4 tracking-wide`} data-theme-target="subtitle">{theme.subtitle}</p>
        
        <p class="text-slate-600 mb-6 font-medium leading-relaxed" data-theme-target="description" set:html={theme.description}></p>
        
        {theme.problems && (
            <ul class="space-y-2 text-sm font-bold text-slate-700 mb-6">
                {theme.problems.map((prob) => (
                    <li class="flex items-center gap-2"><i data-lucide="check-circle-2" class={`w-5 h-5 text-${c.icon}`}></i> {prob}</li>
                ))}
            </ul>
        )}
        
        {theme.id === "03" && (
            <a href="usecase_mobile.html" class="inline-flex items-center gap-2 bg-yellow-50 text-yellow-700 border border-yellow-200 font-bold px-4 py-2 rounded-full text-sm hover:bg-yellow-100 transition shadow-sm">
                <i data-lucide="external-link" class="w-4 h-4"></i> 詳細な利用イメージを見る
            </a>
        )}
        
        {theme.id === "06" && (
            <a href="slides/simulator_presentation.pdf" target="_blank" class="inline-flex items-center gap-2 bg-orange-500 text-white font-bold px-5 py-3 rounded-full text-sm hover:bg-orange-600 transition shadow-md">
                <i data-lucide="file-down" class="w-5 h-5"></i> 提案書（PDF）をダウンロード
            </a>
        )}
        
        {theme.id === "07" && (
            <a href="slides/ai_adjutant_presentation.pdf" target="_blank" class="inline-flex items-center gap-2 bg-indigo-500 text-white font-bold px-5 py-3 rounded-full text-sm hover:bg-indigo-600 transition shadow-md">
                <i data-lucide="file-down" class="w-5 h-5"></i> 提案書（PDF）をダウンロード
            </a>
        )}
    </div>
    <div class="md:w-1/2 bg-slate-50 rounded-2xl p-6 border border-slate-100 w-full flex items-center justify-center gap-4">
        <!-- Generic abstract illustration for the right side -->
        <div class="bg-white p-4 rounded-xl shadow-sm text-center z-10 w-24 border border-slate-200">
            <i data-lucide="box" class={`w-8 h-8 text-${c.icon} mx-auto mb-2`}></i><span class="text-[10px] font-bold">Data Source</span>
        </div>
        <div class={`h-1 ${c.bg} w-8 flex-shrink-0 relative`}><i data-lucide="arrow-right" class={`absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-${c.icon} w-4 h-4`}></i></div>
        <div class={`bg-slate-800 text-white p-4 rounded-full shadow-lg z-10`}><i data-lucide="workflow" class={`w-6 h-6 text-${c.icon}`}></i></div>
        <div class={`h-1 ${c.bg} w-8 flex-shrink-0 relative`}><i data-lucide="arrow-right" class={`absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-${c.icon} w-4 h-4`}></i></div>
        <div class={`${c.bg} ${c.text} p-4 rounded-xl shadow-md text-center z-10 w-28 border-b-4 ${c.border}`}>
            <i data-lucide="database" class={`w-8 h-8 text-${c.icon} mx-auto mb-2`}></i><span class="text-[10px] font-bold">つなげモン DB</span>
        </div>
    </div>
</div>
