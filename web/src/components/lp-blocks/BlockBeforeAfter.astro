---
const { block } = Astro.props;
---
<section id="benefits" data-screen-label={block.title || "導入シナリオ"} style="background:#F7F5F0;padding:clamp(72px,9vw,110px) 24px;scroll-margin-top:70px">
  <div style="max-width:1080px;margin:0 auto">
    <div data-fade="0" style="display:flex;align-items:center;gap:14px;margin:0 0 16px">
      {block.subtitle && <span style="font-size:13px;font-weight:700;letter-spacing:.16em;color:var(--c-accent)">{block.subtitle}</span>}
      <span style="width:36px;height:1px;background:#C9C4B6"></span>
    </div>
    
    {block.title && (
    <h2 data-fade="0" style="margin:0 0 18px;font-size:clamp(26px,3.6vw,38px);font-weight:900;line-height:1.45;letter-spacing:.03em;color:#1F2430;font-feature-settings:'palt';word-break:auto-phrase">
      {block.title}
    </h2>
    )}
    
    {block.desc && (
    <p data-fade="0" style="display:inline-block;margin:0 0 36px;padding:10px 16px;background:#FFFFFF;border:1px solid #D8D4C8;font-size:13.5px;font-weight:700;line-height:1.7;color:#6B7280">
      {block.desc}
    </p>
    )}
    
    <div class="change-grid">
      {block.items && block.items.map((item, index) => (
      <div class="change-card" data-fade={index * 100}>
        {item.image && <div class="change-card-media"><img src={item.image.startsWith('/') || item.image.startsWith('http') || item.image.startsWith('.') ? item.image : `/assets/images/${item.image}`} alt="" width="1280" height="720" loading="lazy" decoding="async"></div>}
        <div class="change-card-content">
          {item.tag && <span style="align-self:flex-start;font-size:12.5px;font-weight:800;letter-spacing:.06em;color:var(--c-primary);border:1px solid color-mix(in oklab, var(--c-primary) 35%, #FFFFFF);padding:4px 10px">{item.tag}</span>}
          <div class="change-before"><span class="change-label">導入前</span><h3>{item.before}</h3></div>
          <div class="change-after"><span class="change-label">導入後</span><p>{item.after}</p></div>
          <p class="change-body">{item.desc}</p>
        </div>
      </div>
      ))}
    </div>
  </div>
</section>
