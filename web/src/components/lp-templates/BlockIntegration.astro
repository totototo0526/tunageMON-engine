---
const { block } = Astro.props;
/*
block = {
  type: "BlockIntegration",
  subtitle: "04",
  title: "すべてを繋ぐハブになる",
  desc: "「つなげモン」が中心となり、現在お使いの様々なシステムをシームレスに連携します。",
  center: "つなげモン DB",
  spokes: [
    { name: "Excel/CSV", icon: "📄" },
    { name: "販売管理", icon: "🏢" },
    { name: "会計ソフト", icon: "💰" },
    { name: "Kintone", icon: "☁️" },
    { name: "チャットツール", icon: "💬" }
  ]
}
*/
---

<section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
        {block.subtitle && (
            <div class="text-center mb-2">
                <span class="inline-block py-1 px-3 rounded-full bg-indigo-100 text-indigo-800 text-sm font-bold tracking-wider">
                    {block.subtitle}
                </span>
            </div>
        )}
        
        {block.title && (
            <h2 class="text-3xl md:text-4xl font-bold text-center text-slate-900 mb-6">
                {block.title}
            </h2>
        )}
        
        {block.desc && (
            <p class="text-center text-slate-600 mb-16 max-w-2xl mx-auto">
                {block.desc}
            </p>
        )}

        <div class="relative py-12 px-4 bg-slate-50 rounded-3xl border border-slate-100 overflow-hidden shadow-inner">
            <!-- Center Node -->
            <div class="relative z-10 flex justify-center items-center mb-16 md:mb-0">
                <div class="bg-indigo-600 text-white font-extrabold text-xl md:text-2xl py-6 px-10 rounded-2xl shadow-xl shadow-indigo-200 border-4 border-white transform hover:scale-105 transition-transform">
                    {block.center}
                </div>
            </div>

            <!-- Spokes / Connecting Nodes -->
            <div class="md:absolute inset-0 flex flex-col md:flex-row justify-center md:items-center gap-6 md:gap-0 mt-8 md:mt-0 z-20 pointer-events-none px-4">
                {block.spokes && block.spokes.map((spoke, idx) => {
                    // Simple positioning for visual flair (desktop)
                    const positions = [
                        "md:absolute md:top-8 md:left-12",
                        "md:absolute md:top-8 md:right-12",
                        "md:absolute md:bottom-8 md:left-12",
                        "md:absolute md:bottom-8 md:right-12",
                        "md:absolute md:top-1/2 md:-translate-y-1/2 md:left-4"
                    ];
                    const posClass = positions[idx % positions.length];
                    
                    return (
                        <div class={`${posClass} bg-white px-5 py-4 rounded-xl shadow-md border border-slate-200 flex items-center gap-3 w-full md:w-auto pointer-events-auto hover:border-indigo-300 transition-colors`}>
                            <div class="text-2xl">{spoke.icon}</div>
                            <div class="font-bold text-slate-700">{spoke.name}</div>
                        </div>
                    );
                })}
            </div>
            
            <!-- Lines pattern background -->
            <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at center, #4f46e5 2px, transparent 2.5px); background-size: 30px 30px;"></div>
        </div>
    </div>
</section>
