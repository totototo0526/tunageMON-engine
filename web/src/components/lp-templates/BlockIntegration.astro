---
const { block } = Astro.props;
/*
block = {
  type: "BlockIntegration",
  subtitle: "04",
  title: "すべてを繋ぐハブになる",
  desc: "「つなげモン」が中心となり、現在お使いの様々なシステムをシームレスに連携します。",
  center: "つなげモン DB",
  spokes: [
    { name: "Excel/CSV", icon: "📄" },
    { name: "販売管理", icon: "🏢" },
    { name: "会計ソフト", icon: "💰" },
    { name: "Kintone", icon: "☁️" },
    { name: "チャットツール", icon: "💬" }
  ]
}
*/
---

<section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
        {block.subtitle && (
            <div class="text-center mb-2">
                <span class="inline-block py-1 px-3 rounded-full bg-indigo-100 text-indigo-800 text-sm font-bold tracking-wider">
                    {block.subtitle}
                </span>
            </div>
        )}
        
        {block.title && (
            <h2 class="text-3xl md:text-4xl font-bold text-center text-slate-900 mb-6">
                {block.title}
            </h2>
        )}
        
        {block.desc && (
            <p class="text-center text-slate-600 mb-16 max-w-2xl mx-auto">
                {block.desc}
            </p>
        )}

        <div class="relative py-16 px-4 bg-slate-50 rounded-3xl border border-slate-100 overflow-hidden shadow-inner">
            <div class="relative z-10 flex flex-col md:flex-row justify-center items-center gap-8 md:gap-16">
                <!-- 左側のシステム（前半） -->
                <div class="flex flex-col gap-4 w-full md:w-64">
                    {block.spokes && block.spokes.slice(0, Math.ceil(block.spokes.length / 2)).map(spoke => (
                        <div class="bg-white px-5 py-4 rounded-xl shadow-md border border-slate-200 flex items-center justify-center md:justify-start gap-3 w-full hover:border-indigo-300 transition-colors z-20">
                            <div class="text-2xl">{spoke.icon}</div>
                            <div class="font-bold text-slate-700">{spoke.name}</div>
                        </div>
                    ))}
                </div>

                <!-- 中央のハブ -->
                <div class="bg-indigo-600 text-white font-extrabold text-xl md:text-2xl py-6 px-10 rounded-2xl shadow-xl shadow-indigo-200 border-4 border-white transform hover:scale-105 transition-transform shrink-0 z-20 text-center">
                    {block.center}
                </div>

                <!-- 右側のシステム（後半） -->
                <div class="flex flex-col gap-4 w-full md:w-64">
                    {block.spokes && block.spokes.slice(Math.ceil(block.spokes.length / 2)).map(spoke => (
                        <div class="bg-white px-5 py-4 rounded-xl shadow-md border border-slate-200 flex items-center justify-center md:justify-start gap-3 w-full hover:border-indigo-300 transition-colors z-20">
                            <div class="text-2xl">{spoke.icon}</div>
                            <div class="font-bold text-slate-700">{spoke.name}</div>
                        </div>
                    ))}
                </div>
            </div>
            
            <!-- Lines pattern background -->
            <div class="absolute inset-0 z-0 opacity-10 pointer-events-none" style="background-image: radial-gradient(circle at center, #4f46e5 2px, transparent 2.5px); background-size: 30px 30px;"></div>
        </div>
    </div>
</section>
