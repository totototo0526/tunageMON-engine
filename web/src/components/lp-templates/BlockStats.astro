---
const { block } = Astro.props;
---

<section class="py-20 bg-gradient-to-br from-blue-50 to-indigo-50">
    <div class="container mx-auto px-4 max-w-5xl">
        {block.subtitle && (
            <div class="text-center mb-2">
                <span class="inline-block py-1 px-3 rounded-full bg-blue-100 text-blue-800 text-sm font-bold tracking-wider">
                    {block.subtitle}
                </span>
            </div>
        )}
        
        {block.title && (
            <h2 class="text-3xl md:text-4xl font-bold text-center text-slate-900 mb-6">
                {block.title}
            </h2>
        )}
        
        {block.desc && (
            <p class="text-center text-slate-600 mb-16 max-w-2xl mx-auto">
                {block.desc}
            </p>
        )}

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {block.items && block.items.map(item => (
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-slate-100 text-center hover:shadow-md transition-shadow">
                    <div class="text-5xl md:text-6xl font-extrabold text-blue-600 mb-4 tracking-tighter">
                        {item.number}
                    </div>
                    <div class="text-xl font-bold text-slate-800 mb-3 border-b-2 border-blue-100 pb-3 inline-block">
                        {item.label}
                    </div>
                    <p class="text-slate-600">
                        {item.desc}
                    </p>
                </div>
            ))}
        </div>
    </div>
</section>
