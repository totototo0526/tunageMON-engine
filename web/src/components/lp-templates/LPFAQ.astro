---
const { theme } = Astro.props;
const faq = theme.data.faq;
---

{faq && faq.length > 0 && (
<section id="faq" data-screen-label="よくある質問" style="background:#FFFFFF;padding:clamp(72px,9vw,110px) 24px;scroll-margin-top:70px">
  <div style="max-width:800px;margin:0 auto">
    <div data-fade="0" style="display:flex;align-items:center;gap:14px;margin:0 0 16px">
      <span style="font-size:13px;font-weight:700;letter-spacing:.16em;color:var(--c-accent)">12</span>
      <span style="width:36px;height:1px;background:#C9C4B6"></span>
    </div>
    <h2 data-fade="0" style="margin:0 0 28px;font-size:clamp(26px,3.6vw,38px);font-weight:900;line-height:1.45;letter-spacing:.03em;color:#1F2430;font-feature-settings:'palt'">よくある質問</h2>
    <div data-fade="0">
      {faq.map((item, index) => (
      <details style={index === 0 ? "border-top:1px solid #E4E1D8" : "border-top:1px solid #E4E1D8" + (index === faq.length - 1 ? ";border-bottom:1px solid #E4E1D8" : "")}>
        <summary style="display:flex;align-items:center;justify-content:space-between;gap:16px;padding:20px 4px;cursor:pointer">
          <span style="font-size:16px;font-weight:700;line-height:1.8;color:#1F2430">{item.q}</span>
          <span data-ind style="flex:none;font-size:22px;font-weight:400;line-height:1;color:var(--c-accent);transition:transform .25s ease">+</span>
        </summary>
        <p style="margin:0;padding:0 28px 22px 4px;font-size:15px;line-height:2;color:#444B59">{item.a}</p>
      </details>
      ))}
    </div>
  </div>
</section>
)}
