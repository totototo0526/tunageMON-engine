---
const { theme } = Astro.props;
const scenarios = theme.data.scenarios;
---

{scenarios && scenarios.length > 0 && (
<section id="benefits" data-screen-label="導入シナリオ" style="background:#F7F5F0;padding:clamp(72px,9vw,110px) 24px;scroll-margin-top:70px">
  <div style="max-width:1080px;margin:0 auto">
    <div data-fade="0" style="display:flex;align-items:center;gap:14px;margin:0 0 16px">
      <span style="font-size:13px;font-weight:700;letter-spacing:.16em;color:var(--c-accent)">03</span>
      <span style="width:36px;height:1px;background:#C9C4B6"></span>
    </div>
    <h2 data-fade="0" style="margin:0 0 18px;font-size:clamp(26px,3.6vw,38px);font-weight:900;line-height:1.45;letter-spacing:.03em;color:#1F2430;font-feature-settings:'palt';word-break:auto-phrase">導入するとこう変わります</h2>
    <p data-fade="0" style="display:inline-block;margin:0 0 36px;padding:10px 16px;background:#FFFFFF;border:1px solid #D8D4C8;font-size:13.5px;font-weight:700;line-height:1.7;color:#6B7280">※以下は実在の事例ではなく、支援内容に基づく想定イメージです。</p>
    <div class="change-grid">
      {scenarios.map((item, index) => (
      <div class="change-card" data-fade={index * 100}>
        <div class="change-card-media"><img src={`../../assets/problems/change-scenarios/${item.image}`} alt="" width="1280" height="720" loading="lazy" decoding="async"></div>
        <div class="change-card-content">
          <span style="align-self:flex-start;font-size:12.5px;font-weight:800;letter-spacing:.06em;color:var(--c-primary);border:1px solid color-mix(in oklab, var(--c-primary) 35%, #FFFFFF);padding:4px 10px">{item.industry}</span>
          <div class="change-before"><span class="change-label">導入前</span><h3>{item.before}</h3></div>
          <div class="change-after"><span class="change-label">導入後</span><p>{item.after}</p></div>
          <p class="change-body">{item.desc}</p>
        </div>
      </div>
      ))}
    </div>
    
    {theme.data.pricing && theme.data.pricing.free_trial && (
    <div class="print-hide" data-fade="0" style="margin-top:44px;background:#FFFFFF;border:1px solid #E4E1D8;padding:22px 26px;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:16px">
      <p style="margin:0;font-size:15.5px;font-weight:700;line-height:1.8;color:#1F2430">まずは<span style="color:var(--c-accent)">1ヶ月の無料トライアル</span>から始められます。</p>
      <a href="https://www.k-sp.co.jp/admin/std/contact/new" style="flex:none;display:inline-block;background:var(--c-accent);color:#FFFFFF;font-size:14px;font-weight:700;letter-spacing:.05em;padding:12px 26px;border-radius:3px;text-decoration:none;transition:filter .2s ease">無料で相談する</a>
    </div>
    )}
  </div>
</section>
)}
