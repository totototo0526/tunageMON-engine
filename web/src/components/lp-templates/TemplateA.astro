---
import LPHero from './LPHero.astro';
import LPProblems from './LPProblems.astro';
import LPPricing from './LPPricing.astro';

import BlockCards from '../lp-blocks/BlockCards.astro';
import BlockBeforeAfter from '../lp-blocks/BlockBeforeAfter.astro';
import BlockFAQ from '../lp-blocks/BlockFAQ.astro';

const { theme } = Astro.props;
---

<style is:global>
/* 原氏のLPスタイルをコンポーネント内にスコープ化（bodyはラッパーに置換） */
.lp-theme-wrapper {
  --c-primary: #1B2A4A;
  --c-accent: #B0543C;
  background: #FFFFFF;
  color: #1F2430;
  font-family: 'Noto Sans JP', ui-sans-serif, system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  font-size: 15px;
}
.lp-theme-wrapper a { color: var(--c-primary); }
.lp-theme-wrapper a:hover { color: var(--c-accent); }
summary{list-style:none;cursor:pointer}
summary::-webkit-details-marker{display:none}
details[open] span[data-ind]{transform:rotate(45deg)}
.reason-list{display:flex;flex-direction:column;gap:clamp(48px,7vw,84px)}
.reason-row{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);align-items:center;gap:clamp(36px,6vw,78px)}
.reason-row.is-even .reason-content{order:1}
.reason-row.is-even .reason-visual{order:2}
.reason-visual{aspect-ratio:4/3;background:#F7F5F0;border:1px solid #E4E1D8;overflow:hidden}
.reason-visual img{display:block;width:100%;height:100%;object-fit:cover}
.reason-content{min-width:0}
.reason-number{display:block;margin:0 0 14px;font-size:13px;font-weight:800;letter-spacing:.16em;color:var(--c-accent)}
.reason-content h4{margin:0 0 14px;font-size:clamp(20px,2.5vw,28px);font-weight:900;line-height:1.55;color:#1F2430;font-feature-settings:'palt';word-break:auto-phrase}
.reason-content p{margin:0;font-size:15.5px;line-height:2;color:#444B59}
.hero-section{position:relative;isolation:isolate;min-height:clamp(620px,76vh,760px);display:flex;align-items:center;overflow:hidden;background:#101E34}
.hero-background{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center center;z-index:-2}
.hero-overlay{position:absolute;inset:0;z-index:-1;background:linear-gradient(90deg,rgba(12,27,49,.96) 0%,rgba(12,27,49,.9) 42%,rgba(12,27,49,.46) 68%,rgba(12,27,49,.12) 100%)}
.hero-layout{width:100%}
.hero-copy{max-width:680px;min-width:0}
.handoff-visual img{display:block;width:100%;height:100%;object-fit:cover}
.hero-badge{color:#FFFFFF!important;background:rgba(255,255,255,.12)!important;border-color:rgba(255,255,255,.38)!important}
.hero-copy h1{font-size:clamp(36px,4.2vw,54px)!important;line-height:1.43!important;color:#FFFFFF!important;text-shadow:0 2px 22px rgba(0,0,0,.22)}
.hero-copy h1 span{color:#FFFFFF!important}
.hero-lead{color:rgba(255,255,255,.92)!important;text-shadow:0 1px 14px rgba(0,0,0,.2)}
.hero-actions a[href="#pricing"]{background:rgba(255,255,255,.08)!important;color:#FFFFFF!important;border-color:rgba(255,255,255,.72)!important}
.hero-service-menu{max-width:760px;margin:0 0 28px}
.hero-service-menu>p{margin:0 0 10px;font-size:12px;font-weight:800;letter-spacing:.14em;color:rgba(255,255,255,.72)}
.hero-service-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:9px}
.hero-service-item{display:flex;align-items:flex-start;gap:9px;min-width:0;padding:12px 13px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.24);color:#FFFFFF;font-size:13px;font-weight:700;line-height:1.65}
.hero-service-index{flex:none;color:#E7A48F;font-size:11px;font-weight:900;letter-spacing:.08em}
.problem-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:18px;max-width:960px;align-items:stretch}
.problem-card{position:relative;display:flex;flex-direction:column;background:#FFFFFF;border:1px solid #E4E1D8;padding:0;min-height:0;overflow:hidden;box-sizing:border-box}
.problem-card-media{position:relative;flex:none;aspect-ratio:16/9;overflow:hidden;background:#F3F1EC;border-bottom:1px solid #E4E1D8}
.problem-card-media img{display:block;width:100%;height:100%;object-fit:cover}
.problem-card-body{display:flex;flex:1;flex-direction:column;padding:24px 26px 25px}
.problem-card h3{margin:0 0 10px;min-height:3.4em;font-size:17px;font-weight:800;line-height:1.7;color:#1F2430;font-feature-settings:'palt'}
.problem-card p{margin:0;font-size:15px;line-height:1.9;color:#444B59}
.problem-cause{max-width:960px;margin:40px 0 0;display:grid;grid-template-columns:minmax(0,1.14fr) minmax(320px,.86fr);align-items:stretch;background:#FFFFFF;border:1px solid #D8D4C8;border-top:3px solid var(--c-primary);overflow:hidden;box-shadow:0 16px 36px rgba(27,42,74,.07)}
.problem-cause-copy{min-width:0;padding:clamp(30px,4vw,46px)}
.problem-cause-kicker{display:block;margin:0 0 13px;font-size:12.5px;font-weight:900;letter-spacing:.12em;color:var(--c-accent)}
.problem-cause h3{margin:0 0 15px;font-size:clamp(20px,2.5vw,27px);font-weight:900;line-height:1.65;color:var(--c-primary);font-feature-settings:'palt';word-break:auto-phrase}
.problem-cause p{margin:0;font-size:15px;line-height:2;color:#444B59}
.problem-cause-bridge{margin-top:18px!important;padding-top:18px;border-top:1px solid #E4E1D8;font-weight:700;color:#1F2430!important}
.problem-cause-visual{min-width:0;background:#F3F1EC;overflow:hidden}
.problem-cause-visual img{display:block;width:100%;height:100%;min-height:100%;object-fit:cover}
.change-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:20px}
.change-card{background:#FFFFFF;border:1px solid #E4E1D8;display:flex;flex-direction:column;overflow:hidden}
.change-card-media{aspect-ratio:16/9;overflow:hidden;background:#F3F1EC;border-bottom:1px solid #E4E1D8}
.change-card-media img{display:block;width:100%;height:100%;object-fit:cover}
.change-card-content{display:flex;flex:1;flex-direction:column;gap:14px;padding:24px}
.change-label{display:block;margin:0 0 9px;font-size:11.5px;font-weight:900;letter-spacing:.12em;color:#767E8C}
.change-before{background:#F4F2ED;border:1px solid #E4E1D8;padding:17px 18px}
.change-before h3{margin:0;font-size:17px;font-weight:800;line-height:1.7;color:#1F2430;font-feature-settings:'palt'}
.change-after{background:color-mix(in oklab,var(--c-primary) 6%,#FFFFFF);border-left:3px solid var(--c-primary);padding:17px 18px}
.change-after .change-label{color:var(--c-primary)}
.change-after p{margin:0;font-size:15px;font-weight:800;line-height:1.75;color:var(--c-primary)}
.change-body{margin:0;font-size:14.5px;line-height:1.95;color:#444B59}
.security-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;margin:0 0 34px}
.security-card{background:#FFFFFF;border:1px solid #E4E1D8;border-top:2px solid var(--c-primary);padding:24px 24px 25px}
.security-card h3{margin:0 0 8px;font-size:17px;font-weight:800;color:#1F2430;font-feature-settings:'palt'}
.security-card p{margin:0;font-size:15px;line-height:1.95;color:#444B59}
.security-flow{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:24px}
.security-flow li{position:relative;background:#F7F5F0;border:1px solid #E4E1D8;padding:18px 14px;text-align:center;font-size:13.5px;font-weight:800;line-height:1.6;color:#1F2430}
.security-flow .flow-arrow{position:absolute;right:-19px;top:50%;transform:translateY(-50%);color:var(--c-accent);font-size:20px;font-weight:900}
.handoff-layout{display:grid;grid-template-columns:minmax(0,1.05fr) minmax(360px,.95fr);gap:clamp(34px,5vw,64px);align-items:center}
.handoff-copy{min-width:0;grid-column:1;grid-row:1}
.handoff-visual{grid-column:2;grid-row:1;aspect-ratio:4/3;overflow:hidden;background:#F7F5F0;border:1px solid #E4E1D8;box-shadow:0 16px 36px rgba(27,42,74,.1)}
.handoff-note{grid-column:1/-1}
.purpose-intro{display:grid;grid-template-columns:minmax(0,.86fr) minmax(0,1.14fr);gap:clamp(40px,6vw,78px);align-items:start}
.purpose-intro h2{margin:0;font-size:clamp(28px,3.8vw,40px);font-weight:900;line-height:1.55;letter-spacing:.03em;color:#FFFFFF;font-feature-settings:'palt';word-break:auto-phrase}
.purpose-story{min-width:0;padding-top:5px}
.purpose-story p{margin:0;font-size:15.5px;line-height:2.05;color:rgba(255,255,255,.84)}
.purpose-story p+p{margin-top:20px}
.purpose-goals{margin-top:50px}
.purpose-kicker{margin:0 0 16px;font-size:12.5px;font-weight:800;letter-spacing:.14em;color:#E7A48F}
.purpose-goal-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}
.purpose-goal-card{position:relative;min-width:0;padding:25px 24px 27px;background:rgba(255,255,255,.075);border:1px solid rgba(255,255,255,.16);border-top:2px solid #E7A48F;box-sizing:border-box}
.purpose-goal-number{display:block;margin:0 0 14px;font-size:11.5px;font-weight:900;letter-spacing:.14em;color:#E7A48F}
.purpose-goal-card h3{margin:0 0 11px;font-size:20px;font-weight:900;line-height:1.65;color:#FFFFFF;font-feature-settings:'palt'}
.purpose-goal-card p{margin:0;font-size:14px;line-height:1.9;color:rgba(255,255,255,.72)}
.purpose-closing{display:grid;grid-template-columns:minmax(0,.86fr) minmax(0,1.14fr);gap:clamp(34px,5vw,64px);align-items:center;margin-top:24px;padding:28px 30px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);box-sizing:border-box}
.purpose-closing-label{display:block;margin:0 0 9px;font-size:11.5px;font-weight:900;letter-spacing:.14em;color:#E7A48F}
.purpose-closing h3{margin:0;font-size:clamp(22px,2.8vw,28px);font-weight:900;line-height:1.65;color:#FFFFFF;font-feature-settings:'palt'}
.purpose-closing-copy p{margin:0;font-size:15px;line-height:2;color:rgba(255,255,255,.82)}
.purpose-closing-copy p+p{margin-top:12px}
.purpose-closing-copy strong{color:#FFFFFF;font-weight:800}

@media(max-width:900px){
  .hero-background{object-position:72% center}
  .handoff-layout{grid-template-columns:1fr}
  .handoff-visual{order:1;grid-column:1;grid-row:auto;max-width:720px}
  .handoff-copy{order:2;grid-column:1;grid-row:auto}
  .change-grid{grid-template-columns:1fr}
  .problem-cause{grid-template-columns:1fr}
  .problem-cause-visual{aspect-ratio:3/2}
}
@media(max-width:760px){
  .hero-service-list{grid-template-columns:1fr}
  .hero-service-item{padding:10px 12px}
  .reason-list{gap:52px}
  .reason-row{grid-template-columns:1fr;gap:22px}
  .reason-row .reason-visual,.reason-row.is-even .reason-visual{order:1}
  .reason-row .reason-content,.reason-row.is-even .reason-content{order:2}
  .hero-section{min-height:780px;align-items:flex-end;padding-top:86px!important;padding-bottom:58px!important}
  .hero-background{object-position:82% center}
  .hero-overlay{background:linear-gradient(180deg,rgba(12,27,49,.72) 0%,rgba(12,27,49,.88) 40%,rgba(12,27,49,.97) 100%)}
  .hero-copy h1{font-size:clamp(29px,8vw,36px)!important;line-height:1.5!important}
  .hero-actions a{width:100%;box-sizing:border-box;text-align:center}
  .problem-grid{grid-template-columns:1fr}
  .problem-card{min-height:0}
  .problem-card-body{padding:22px 23px 24px}
  .problem-card h3{min-height:0}
  .problem-cause{margin-top:30px}
  .problem-cause-copy{padding:26px 23px}
  .security-grid{grid-template-columns:1fr}
  .security-flow{grid-template-columns:1fr;gap:28px}
  .security-flow .flow-arrow{right:50%;top:auto;bottom:-25px;transform:translateX(50%) rotate(90deg)}
  .handoff-layout{gap:24px}
  .purpose-intro{grid-template-columns:1fr;gap:24px}
  .purpose-story{padding-top:0}
  .purpose-goals{margin-top:38px}
  .purpose-goal-grid{grid-template-columns:1fr;gap:12px}
  .purpose-goal-card{padding:22px 21px 23px}
  .purpose-closing{grid-template-columns:1fr;gap:20px;margin-top:16px;padding:24px 22px}
}
</style>

<div class="lp-theme-wrapper">
    <!-- ヒーローセクションから下のみを配置（ヘッダー等はLPLayoutから提供） -->
    <LPHero theme={theme} />
    
    <LPProblems theme={theme} />
    
    {theme.data.blocks && theme.data.blocks.map(block => {
        if (block.type === 'BlockCards') return <BlockCards block={block} />;
        if (block.type === 'BlockBeforeAfter') return <BlockBeforeAfter block={block} />;
        if (block.type === 'BlockFAQ') return <BlockFAQ block={block} />;
        return null;
    })}

    <slot />

    <LPPricing theme={theme} />
</div>

<script>
// Fade Animation Observer
const initFade = () => {
    if (window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const io = new IntersectionObserver(ents => {
      ents.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0, rootMargin: '0px 0px -4% 0px' });
    
    document.querySelectorAll('[data-fade]').forEach(el => {
      const d = parseInt(el.getAttribute('data-fade'), 10) || 0;
      el.style.opacity = '0';
      el.style.transform = 'translateY(14px)';
      el.style.transition = 'opacity .55s cubic-bezier(.2,.6,.2,1) ' + d + 'ms, transform .55s cubic-bezier(.2,.6,.2,1) ' + d + 'ms';
      io.observe(el);
    });
};

document.addEventListener("DOMContentLoaded", initFade);
</script>
